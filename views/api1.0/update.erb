<%
begin
    object = params[:object]
    cls = BlackStack::API.classes[object.to_sym]
    desc = @body['desc']
    raise "desc is required" if desc.nil?
    raise "id is required" if desc['id'].nil?
    o = nil
    if @account.sysowner?
        o = cls.where(:id=>desc['id']).first
    else
        o = cls.where(:id=>desc['id'], :id_account=>@account.id).first
    end
    raise "id not found" if o.nil?
    desc['id_account'] = @account.id
    o = o.update(desc)

    # Job responses can become extremely expensive when serializing nested events.
    # For SDK flows we only need a lightweight acknowledgement after update.
    if object.to_s == 'job' && o.respond_to?(:to_h_compact)
        @return_message['result'] = o.to_h_compact
    else
        @return_message['result'] = o.to_h
    end
rescue Exception => e
    @return_message['status'] = @body['backtrace'] ? e.to_console : e.message
end
return @return_message.to_json
%>
